{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=DeskIQ_Tickets;Username=postgres;Password=CHANGE_ME"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Jwt": {
    "Key": "dev-only-key-change-in-real-env-at-least-32-characters",
    "Issuer": "DeskIQ.TicketSystem",
    "Audience": "DeskIQ.TicketSystem",
    "ExpireMinutes": 1440
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:3000",
      "http://127.0.0.1:63098"
    ]
  },
  "Email": {
    "DefaultFrom": "noreply@deskiq.com"
  },
  "FileUpload": {
    "MaxFileSize": 10485760,
    "MaxFilesPerTicket": 10,
    "AllowedExtensions": ".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.txt,.csv"
  },
  "FileStorage": {
    "BasePath": "./uploads",
    "TicketsPath": "tickets"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
