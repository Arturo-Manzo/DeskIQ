# Common runtime settings
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL
POSTGRES_DB=DeskIQ_Tickets
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev123
POSTGRES_HOST_PORT=5433

# Redis
REDIS_HOST_PORT=6379

# API/Client ports
API_HOST_PORT=5000
CLIENT_HOST_PORT=3000
FRONTEND_HOST_PORT=4200

# Frontend runtime config
DESKIQ_FRONTEND_API_BASE_URL=http://localhost:5000

# JWT
JWT_KEY=change-me-development-key-min-32-chars
JWT_ISSUER=DeskIQ.TicketSystem
JWT_AUDIENCE=DeskIQ.TicketSystem
JWT_EXPIRE_MINUTES=1440

# CORS (backend)
CORS_ALLOWED_ORIGIN_0=http://localhost:4200
CORS_ALLOWED_ORIGIN_1=http://localhost:3000

# Local script override for API connection string (optional)
# APP_CONNECTION_STRING=Host=localhost;Port=5433;Database=DeskIQ_Tickets;Username=postgres;Password=postgres123
